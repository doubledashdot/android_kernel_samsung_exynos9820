CONFIG_KSU=y
# CONFIG_KSU_KPROBES_KSUD is not set
# CONFIG_KSU_HACK_ARM64_BRANCH_LINK is not set
CONFIG_KSU_TAMPER_SYSCALL_TABLE=y
CONFIG_KSU_FEATURE_SULOG=y
CONFIG_KSU_FEATURE_ADBROOT=y
# CONFIG_KSU_FEATURE_ADBROOT_DEFAULT_ENABLE is not set
# CONFIG_KSU_DEBUG is not set
# CONFIG_KSU_THRONE_TRACKER_ALWAYS_THREADED is not set
CONFIG_KSU_LSM_SECURITY_HOOKS=y
CONFIG_KSU_HEURISTIC_IN_TREE_BUILD=y
